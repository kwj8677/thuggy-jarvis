#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo 'Usage: psw "<PowerShell command>"' >&2
  exit 2
fi

if command -v pwsh.exe >/dev/null 2>&1; then
  pwsh.exe -NoProfile -NonInteractive -Command "$1"
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -NonInteractive -Command "$1"
else
  /mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -NonInteractive -Command "$1"
fi
