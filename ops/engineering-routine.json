{
  "version": "2026-03-11",
  "owner": "yeonjin",
  "goal": "stable-first",
  "workflow": {
    "stepOrder": [
      "first-principles-analysis",
      "single-change",
      "smoke-3",
      "batch-10",
      "decision",
      "docs-update"
    ],
    "updateRoutine": [
      "collect-references",
      "github-related-sources",
      "comparative-meta-analysis",
      "smoke-3-and-batch-10",
      "apply-change",
      "sync-md-json",
      "commit-and-push",
      "report-fixed-format"
    ],
    "singleChangeOnly": true,
    "requireDocsSync": true
  },
  "guards": {
    "maxRetry": 1,
    "cooldownSec": 30,
    "singleInstanceLock": true,
    "circuitBreakConsecutiveFailures": 3,
    "nonRetryableErrors": [
      "Action not found",
      "Invalid config",
      "No such file",
      "Unknown stage",
      "mapping"
    ],
    "apiCallCap": 50,
    "stageTimeoutSec": 180
  },
  "qualityGate": {
    "minSuccessRate": 0.9,
    "maxFallbackRate": 0.2,
    "maxRetryRate": 0.1,
    "requireErrorBucketNoneForHealthyRun": true
  },
  "reporting": {
    "format": [
      "double-check",
      "conclusion",
      "cold-counterpoint",
      "next-action"
    ],
    "includeFiles": [
      "*.log",
      "*.summary.json"
    ]
  },
  "changeControl": {
    "requireApprovalForHighRisk": true,
    "gatewayRestartRequiresApproval": true,
    "restartOncePerBatch": true
  },
  "weeklyMaintenance": {
    "checkProfileDrivenRunBaseline": true,
    "checkRoleBasedApiCountTrend": true,
    "checkReferenceTriage": true
  },
  "referenceTriage": {
    "apply": [
      "polly-retry-fallback-circuit-pattern",
      "playwright-flaky-retry-concepts",
      "sre-runbook-discipline"
    ],
    "hold": [
      "full-opentelemetry-integration",
      "multi-browser-expansion-beyond-baseline"
    ],
    "observe": [
      "retry-recovery-rate-429",
      "operational-resilience-score-drift",
      "role-based-api-count-trend"
    ]
  },
  "verificationStatus": {
    "profileDrivenExecution": "verified",
    "roleBasedApiCounting": "verified"
  },
  "apiEfficiency": {
    "avoidDuplicateCalls": true,
    "avoidTightPolling": true,
    "batchSimilarOperations": true
  },
  "vibeCodingSafety": {
    "singleChangePerCycle": true,
    "verifyByReproducibility": true,
    "fixedGuardsRequired": true,
    "stateBasedSuccessRequired": true,
    "mdJsonSyncRequired": true,
    "fixedReportFormatRequired": true
  }
}
