{
  "version": "2026-03-11",
  "mode": "relayless",
  "goal": "stable-browsering",
  "flow": [
    "normalize-query",
    "discover-sources",
    "fetch-top-n",
    "error-bucket-classification",
    "conditional-retry",
    "evidence-check",
    "summarize",
    "save-report"
  ],
  "guards": {
    "maxRetry": 1,
    "cooldownSec": 30,
    "avoidTightPolling": true,
    "singleChangePerCycle": true,
    "failFastOnEmptyContent": true
  },
  "errorPolicy": {
    "DNS_ENOTFOUND": { "retry": 0, "action": "fail-fast" },
    "BLOCKED_SPECIAL_IP": { "retry": 0, "action": "fail-fast" },
    "CONFIG": { "retry": 0, "action": "fail-fast" },
    "NETWORK_OR_FETCH": { "retry": 1, "action": "retry-once", "backoffSec": 1 },
    "TIMEOUT": { "retry": 1, "action": "retry-once", "backoffSec": 2 },
    "HTTP_5XX": { "retry": 1, "action": "retry-once", "backoffSec": 1 },
    "HTTP_429": { "retry": 1, "action": "retry-with-retry-after", "backoffSec": 2, "respectRetryAfterHeader": true, "maxRetryAfterSec": 10 }
  },
  "qualityGate": {
    "minFetchSuccessRate": 0.9,
    "requireCitations": true,
    "requireConclusion": true
  }
}
