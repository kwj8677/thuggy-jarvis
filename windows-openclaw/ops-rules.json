{
  "windowsExecution": {
    "preferredInvoker": "psw",
    "complexInvoker": "fsw",
    "pattern": "psw \"<PowerShell command>\"",
    "examples": [
      "psw \"Get-Date\"",
      "psw \"Get-Process | Select -First 3\"",
      "psw \"Start-Process notepad\""
    ],
    "notes": [
      "Always execute Windows actions through pwsh invocation from WSL.",
      "Prefer one-line command strings for reproducibility and logs.",
      "Prioritize stability/availability over strict hardening when trade-offs exist; confirm before high-risk changes."
    ],
    "priority": {
      "stability": "highest",
      "security": "important_but_secondary"
    }
  },
  "guiAutomation": {
    "goal": "macos-like high-reliability GUI control on Windows",
    "executionOrder": [
      "browser_tool_or_agent_browser",
      "powershell_uia",
      "ahk_fallback"
    ],
    "web": {
      "primary": "browser tool (profile=openclaw or chrome when relay tab is attached)",
      "secondary": "agent-browser (ref-based click/type/snapshot)",
      "verification": "browser tabs/snapshot change before declaring success"
    },
    "windowsNative": {
      "primary": "PowerShell UI Automation (element-first)",
      "fallback": "AHK relative coordinates/image search",
      "preconditions": [
        "target window active",
        "window restored/maximized",
        "DPI-aware offsets"
      ]
    },
    "ahk": {
      "engine": "AutoHotkey v2",
      "installer": "psw \"choco install autohotkey -y\"",
      "runner": "psw \"& C:\\openclaw\\run.ps1 -Action <name>.ahk -TimeoutSec <n>\"",
      "scriptGuards": [
        "#SingleInstance Force",
        "#NoTrayIcon",
        "hard timeout via SetTimer -> ExitApp(nonzero)"
      ]
    },
    "validation": {
      "required": true,
      "signals": [
        "browser tabs not empty (relay attach)",
        "window/control state changed",
        "expected output/file/process evidence"
      ],
      "rule": "click dispatched != success"
    },
    "learning": {
      "calibrationFile": "C:\\openclaw\\relay-calibration.json",
      "scoreFile": "C:\\openclaw\\relay-learn.json",
      "policy": [
        "promote successful points",
        "deprioritize failed points",
        "mark deprecated after >=3 repeated failures"
      ]
    }
  },
  "actionRunner": {
    "path": "C:\\openclaw\\run.ps1",
    "policy": "C:\\openclaw\\action-policy.json",
    "logs": "C:\\openclaw\\logs",
    "features": [
      "timeout",
      "retry",
      "backoff",
      "risk-level",
      "approval-gate",
      "meta-json-log"
    ]
  },
  "secretsPolicy": {
    "sourceOfTruth": "secrets/local-secrets.json",
    "rules": [
      "Do not rely on memory for secrets.",
      "Read secrets from local-secrets.json before auth-sensitive operations.",
      "Commit only secrets.example.json, never real secrets."
    ]
  },
  "contextManagement": {
    "userInterface": "single-thread-chat",
    "internalRouting": "auto",
    "domains": [
      "operations",
      "marketing",
      "experiments"
    ],
    "reporting": "merged-summary",
    "requireUserTags": false,
    "notes": [
      "User should not need to manually tag context.",
      "Agent auto-classifies intent and routes internally.",
      "Results are returned in one coherent reply."
    ]
  }
}
